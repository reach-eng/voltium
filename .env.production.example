# Voltium Production Environment Variables
# Copy this to your production environment with real values.

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8081
NEXT_PUBLIC_APP_URL="https://voltium.in"

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Use a connection-pooled URL for production
DATABASE_URL="postgresql://user:password@host:5432/voltium?schema=public&connection_limit=10"

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"
ALLOWED_ORIGINS="https://voltium.in,https://admin.voltium.in"

# ── Redis (Upstash) — Rate limiting & OTP storage ─────────────────────────
# Required for multi-instance deployments
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── SMS Provider (msg91 or twilio) ────────────────────────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_PHONE=""

# ── Cloud Storage (GCS) ───────────────────────────────────────────────────
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME="voltium-uploads"
GCS_PROJECT_ID="voltium-production"

# ── Monitoring ─────────────────────────────────────────────────────────────
SENTRY_DSN=""

# ── Feature Flags ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_KYC=true
NEXT_PUBLIC_ENABLE_GUARANTOR=true
NEXT_PUBLIC_ENABLE_REWARDS=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# ── Dev Tools — must be false in production ───────────────────────────────
ENABLE_DEV_TOOLS=false
