# Voltium Production Environment
# Copy this file to .env.production and fill in the values.

NODE_ENV=production
APP_ENV=production
DATA_MODE=local_laptop

DATABASE_URL=postgresql://user:password@production-host:5432/voltium_prod
JWT_SECRET=<generate-a-64-char-random-secret>
ALLOWED_ORIGINS=https://voltium.app,https://admin.voltium.app
NEXT_PUBLIC_APP_URL=https://voltium.app

# --- Local Storage ---
# LOCAL_STORAGE_ROOT=D:/VoltiumServer/data/uploads

# --- Data Management ---
DATA_MANAGEMENT_ENABLED=true
BACKUP_ROOT=D:/VoltiumServer/data/backups
BACKUP_SECONDARY_ROOT=E:/VoltiumBackups
BACKUP_ENCRYPTION_ENABLED=false
