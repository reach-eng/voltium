# Voltium Environment Variables Example
# Copy this file to .env and fill in the values.

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voltium?schema=public"

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:3000"

# ── Application URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:8081"

# ── Redis (Upstash) — Rate limiting & OTP storage ─────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── SMS Provider (mock, msg91) ────────────────────────────────────────────
SMS_PROVIDER=mock
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# ── Twilio (alternative SMS) ──────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_PHONE=""

# ── Cloud Storage (local or gcs) ──────────────────────────────────────────
STORAGE_PROVIDER=local
# GCS_BUCKET_NAME=""
# GCS_PROJECT_ID=""

# ── Monitoring ─────────────────────────────────────────────────────────────
# SENTRY_DSN=""

# ── Feature Flags ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_KYC=true
NEXT_PUBLIC_ENABLE_GUARANTOR=true
NEXT_PUBLIC_ENABLE_REWARDS=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# ── Dev Tools (only when NODE_ENV=development) ────────────────────────────
# Set to "true" to enable test shortcuts (mock KYC, mock payments, etc.)
ENABLE_DEV_TOOLS=false
