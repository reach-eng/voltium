# Voltium Environment Variables Example
# Copy this file to .env and fill in the values.

# --- Environment ---
NODE_ENV=development
APP_ENV=development
DATA_MODE=default

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voltium?schema=public

# --- Security ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# --- Application URL ---
NEXT_PUBLIC_APP_URL=http://localhost:8081

# --- SMS Provider ---
SMS_PROVIDER=mock
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# --- Local Storage ---
# LOCAL_STORAGE_ROOT=D:/VoltiumServer/data/uploads

# --- Data Management ---
DATA_MANAGEMENT_ENABLED=true
BACKUP_ROOT=D:/VoltiumServer/data/backups
BACKUP_SECONDARY_ROOT=E:/VoltiumBackups
BACKUP_ENCRYPTION_ENABLED=false

# --- Monitoring ---
# SENTRY_DSN=

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_KYC=true
NEXT_PUBLIC_ENABLE_GUARANTOR=true
NEXT_PUBLIC_ENABLE_REWARDS=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# --- Dev Tools ---
ENABLE_DEV_TOOLS=false
