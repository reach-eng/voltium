    "@types/react-dom": "^18.2.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.3.5",
