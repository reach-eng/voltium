{
  "name": "voltium-electric-mobility",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev -p 8081 -H 0.0.0.0",
    "build": "next build && node -e \"const fs=require('fs');fs.cpSync('.next/static','.next/standalone/.next/static',{recursive:true,force:true});fs.cpSync('public','.next/standalone/public',{recursive:true,force:true});\"",
    "start": "cross-env NODE_ENV=production node .next/standalone/server.js",
    "start:win": "cross-env NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint . --max-warnings 425",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "npx tsx prisma/seed.ts",
    "worker:dev": "tsx src/server/workers/index.ts",
    "worker:build": "esbuild src/server/workers/index.ts --bundle --platform=node --outfile=dist/workers.js --alias:@=./src --external:@prisma/client --external:next --external:@sentry/nextjs --external:sharp",
    "worker:start": "node dist/workers.js",
    "generate:openapi": "npx tsx src/contracts/openapi.ts",
    "test:contracts": "vitest --run src/contracts/__tests__/",
    "test": "vitest",
    "test:unit": "vitest --run tests/unit",
    "test:api": "vitest tests/api-routes.test.ts",
    "test:e2e": "npx playwright test",
    "test:onboarding": "npx playwright test e2e/onboarding-flow.spec.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "check:no-docker": "bash ../scripts/check-no-docker.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@mdxeditor/editor": "^3.39.1",
    "@prisma/client": "^6.11.1",
    "@prisma/extension-accelerate": "^3.0.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
