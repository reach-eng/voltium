# Voltium — Environment Variable Reference
# Copy this file to .env and fill in values before running.
# All variables marked [REQUIRED] must be set in production.
# All variables marked [SECRET] must be strong, unique, and never committed.
#
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Runtime Mode ────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production            # development | test | staging | production
DATA_MODE=local_laptop        # Must be 'local_laptop' in production

# ─── Database [REQUIRED] ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://voltium_user:strong_password@localhost:5432/voltium_prod
# Optional: direct URL for migrations when using a connection pooler (e.g. PgBouncer)
# DIRECT_URL=postgresql://voltium_user:strong_password@localhost:5432/voltium_prod

# ─── Security Secrets [REQUIRED][SECRET] ─────────────────────────────────────
# Minimum 32 characters each. Generate with the command above.
JWT_SECRET=YOUR_SECURE_JWT_SECRET_MIN_32_CHARS_LONG
# HMAC key used to sign FCM command payloads — rotate if compromised
FCM_COMMAND_HMAC_SECRET=YOUR_SECURE_FCM_HMAC_SECRET_MIN_32_CHARS_LONG
# Secret for cron endpoint authentication [REQUIRED in production]
CRON_SECRET=YOUR_SECURE_CRON_SECRET_MIN_32_CHARS_LONG
# Secret for internal worker-to-API calls [REQUIRED in production]
WORKER_SECRET=YOUR_SECURE_WORKER_SECRET_MIN_32_CHARS_LONG
# Optional: session cookie secret (defaults to JWT_SECRET if not set)
# SESSION_SECRET=YOUR_SECURE_SESSION_SECRET_MIN_32_CHARS_LONG

# ─── Storage (local mode) [REQUIRED] ─────────────────────────────────────────
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=D:\voltium-data\uploads
BACKUP_ROOT=D:\voltium-data\backups
# Optional: secondary backup location (e.g. external drive)
BACKUP_SECONDARY_ROOT=E:\voltium-backups

# ─── Backup Encryption (optional) ─────────────────────────────────────────────
# Enable AES-256-GCM encryption for backup files at rest
BACKUP_ENCRYPTION_ENABLED=false
# 64 hex characters = 32-byte AES-256 key [SECRET]
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BACKUP_ENCRYPTION_KEY=64_hex_characters_here

# ─── Application URL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:8081
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8081  # defaults to NEXT_PUBLIC_APP_URL

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock             # mock | msg91
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-otp-template-id

# ─── Firebase / FCM (optional) ────────────────────────────────────────────────
# Required only if Firebase push notifications or authentication are active.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Data Management ──────────────────────────────────────────────────────────
DATA_MANAGEMENT_ENABLED=false  # Set to true to enable admin backup/restore UI
MAINTENANCE_MODE=false

# ─── Dev/Test Bypasses (NEVER enable in production or staging) ────────────────
ENABLE_TEST_OTP=false         # Accepts OTP '123456' for any phone — DEV ONLY
ENABLE_DEV_ADMIN_LOGIN=false  # Allows passwordless admin login — DEV ONLY

# ─── Feature Flags (client-visible) ──────────────────────────────────────────
NEXT_PUBLIC_ENABLE_KYC=true
NEXT_PUBLIC_ENABLE_GUARANTOR=true
NEXT_PUBLIC_ENABLE_REWARDS=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
