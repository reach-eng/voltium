# Voltium Staging Environment Variables
# Copy this file to .env.staging and fill in the values.
# Staging connects to staging infrastructure and services.

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=staging

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Staging Postgres instance (e.g., Neon, Railway, Supabase)
DATABASE_URL="postgresql://postgres:password@staging-db.example.com:5432/voltium_staging?schema=public"

# ── Security ───────────────────────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET"

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="https://staging.voltium.app"

# ── Application URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://staging.voltium.app"

# ── Redis (Upstash) — Rate limiting & OTP storage ─────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── SMS Provider (mock, msg91) ────────────────────────────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# ── Cloud Storage (local or gcs) ──────────────────────────────────────────
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME="voltium-staging-uploads"
GCS_PROJECT_ID=""

# ── Monitoring ─────────────────────────────────────────────────────────────
SENTRY_DSN=""

# ── Feature Flags ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_KYC=true
NEXT_PUBLIC_ENABLE_GUARANTOR=true
NEXT_PUBLIC_ENABLE_REWARDS=true
NEXT_PUBLIC_ENABLE_REFERRAL=true

# ── Dev Tools — DISABLED in staging (production NODE_ENV) ─────────────────
ENABLE_DEV_TOOLS=false
ENABLE_TEST_OTP=false
ENABLE_DEV_ADMIN_LOGIN=false
