# Voltium Staging Environment
# Copy this file to .env.staging and fill in the values.

NODE_ENV=production
APP_ENV=staging
DATA_MODE=local_laptop

DATABASE_URL=postgresql://user:password@staging-host:5432/voltium_staging
JWT_SECRET=<generate-a-64-char-random-secret>
ALLOWED_ORIGINS=https://staging.voltium.app
NEXT_PUBLIC_APP_URL=https://staging.voltium.app

# --- Local Storage ---
# LOCAL_STORAGE_ROOT=D:/VoltiumServer/data/uploads

# --- Data Management ---
DATA_MANAGEMENT_ENABLED=true
BACKUP_ROOT=D:/VoltiumServer/data/backups
BACKUP_SECONDARY_ROOT=E:/VoltiumBackups
BACKUP_ENCRYPTION_ENABLED=false
